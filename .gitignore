# Temporary publish site:
_site/

# General outputs:
*.pdf
*.html
*.tex
*.typ
*_files/

# Keep templates:
!**/_assets/*.tex
!**/_assets/*.typ

# Quarto:
/.quarto/
**/*.quarto_ipynb*
**/*.quarto_ipynb

# Keep typ under physics/
!physics/**/*.typ
**/.calepin/*

# Notebook temporaries?
.cache/
*.vdoc.*

# Python
__pycache__/
*.pyc
*.pyo

# Any sandbox:
*sandbox*
